{
  "name": "finance-zap",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "ci:check": "node scripts/ci-check.mjs",
    "dev": "tsx watch src/app/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/app/server.js",
    "lint": "eslint --max-warnings 0 \"src/**/*.ts\" \"tests/**/*.ts\" \"prisma/**/*.ts\"",
    "lint:fix": "eslint --fix \"src/**/*.ts\" \"tests/**/*.ts\" \"prisma/**/*.ts\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:all": "tsc --noEmit -p tsconfig.eslint.json",
    "setup:env": "node scripts/ensure-env.mjs",
    "setup:audio": "node scripts/ensure-env.mjs && node scripts/setup-audio.mjs",
    "prisma:generate": "node scripts/ensure-env.mjs && dotenv -e .env -- prisma generate",
    "prisma:migrate": "node scripts/ensure-env.mjs && dotenv -e .env -- prisma migrate dev",
    "prisma:migrate:deploy": "node scripts/ensure-env.mjs && dotenv -e .env -- prisma migrate deploy",
    "prisma:seed": "node scripts/ensure-env.mjs && dotenv -e .env -- prisma db seed",
    "db:up": "docker compose up -d postgres",
    "db:ready": "node scripts/wait-for-postgres.mjs",
    "bootstrap": "yarn setup:env && yarn db:up && yarn db:ready && yarn prisma:generate && yarn prisma:migrate:deploy && yarn prisma:seed",
    "docker:up": "docker compose up --build",
    "docker:up:detached": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@fastify/sensible": "^6.0.3",
    "@prisma/client": "^6.5.0",
    "@whiskeysockets/baileys": "^6.7.21",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "decimal.js": "^10.5.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.5",
    "tesseract.js": "^6.0.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/node": "^22.13.10",
    "@types/qrcode-terminal": "^0.12.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.21.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1",
    "vitest": "^3.0.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
