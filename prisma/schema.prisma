generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageProvider {
  WHATSAPP
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  OTHER
}

enum TransactionType {
  EXPENSE
  INCOME
  TRANSFER
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

enum CategoryKind {
  EXPENSE
  INCOME
  BOTH
}

enum RuleMatchType {
  CONTAINS
  STARTS_WITH
  REGEX
  NORMALIZED_EQUALS
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  UNKNOWN
}

enum ReminderStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ReminderRecurrence {
  NONE
  DAILY
  WEEKLY
  MONTHLY
}

enum ReminderSource {
  TEXT
  AUDIO
  WHATSAPP_OTHER
}

model User {
  id                      String    @id @default(uuid()) @db.Uuid
  whatsappNumber          String    @unique @map("whatsapp_number")
  displayName             String?   @map("display_name")
  waChatJid               String?   @map("wa_chat_jid")
  timezone                String    @default("America/Sao_Paulo")
  locale                  String    @default("pt-BR")
  onboardingWelcomeSentAt DateTime? @map("onboarding_welcome_sent_at")
  lastInboundAt           DateTime? @map("last_inbound_at")
  lastDailySummaryForDate String?   @map("last_daily_summary_for_date")
  lastPinNudgeAt          DateTime? @map("last_pin_nudge_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  messages             Message[]
  transactions         Transaction[]
  categories           Category[]
  rules                Rule[]
  recurringPatterns    RecurringPattern[]
  auditLogs            AuditLog[]
  pendingConfirmations PendingConfirmation[]
  reminders            UserReminder[]

  @@map("users")
}

model Message {
  id                String           @id @default(uuid()) @db.Uuid
  userId            String           @map("user_id") @db.Uuid
  provider          MessageProvider
  providerMessageId String           @map("provider_message_id")
  direction         MessageDirection
  messageType       MessageType      @map("message_type")
  rawText           String?          @map("raw_text") @db.Text
  processedText     String?          @map("processed_text") @db.Text
  mediaPath         String?          @map("media_path")
  mediaMimeType     String?          @map("media_mime_type")
  intent            String?
  confidence        ConfidenceLevel?
  metadata          Json             @default("{}")
  receivedAt        DateTime         @map("received_at")
  createdAt         DateTime         @default(now()) @map("created_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, provider, providerMessageId])
  @@index([userId, receivedAt])
  @@map("messages")
}

model Category {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String?      @map("user_id") @db.Uuid
  name           String
  normalizedName String       @map("normalized_name")
  kind           CategoryKind
  isSystem       Boolean      @default(false) @map("is_system")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user              User?              @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  rules             Rule[]
  recurringPatterns RecurringPattern[]

  @@index([userId, normalizedName])
  @@index([isSystem, normalizedName])
  @@map("categories")
}

model Transaction {
  id                    String            @id @default(uuid()) @db.Uuid
  userId                String            @map("user_id") @db.Uuid
  sourceMessageId       String?           @map("source_message_id") @db.Uuid
  type                  TransactionType
  amount                Decimal           @db.Decimal(18, 4)
  currency              String            @default("BRL")
  description           String            @db.Text
  normalizedDescription String            @map("normalized_description") @db.Text
  categoryId            String?           @map("category_id") @db.Uuid
  subcategory           String?
  occurredAt            DateTime          @map("occurred_at")
  status                TransactionStatus @default(CONFIRMED)
  confidence            ConfidenceLevel
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")
  deletedAt             DateTime?         @map("deleted_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  message  Message?  @relation(fields: [sourceMessageId], references: [id], onDelete: SetNull)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, occurredAt])
  @@index([userId, deletedAt])
  @@map("transactions")
}

model Rule {
  id              String           @id @default(uuid()) @db.Uuid
  userId          String           @map("user_id") @db.Uuid
  name            String
  matchType       RuleMatchType    @map("match_type")
  matchValue      String           @map("match_value") @db.Text
  transactionType TransactionType? @map("transaction_type")
  categoryId      String?          @map("category_id") @db.Uuid
  priority        Int              @default(0)
  isActive        Boolean          @default(true) @map("is_active")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId, isActive, priority])
  @@map("rules")
}

model RecurringPattern {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @map("user_id") @db.Uuid
  fingerprint     String
  description     String             @db.Text
  categoryId      String?            @map("category_id") @db.Uuid
  estimatedAmount Decimal?           @map("estimated_amount") @db.Decimal(18, 4)
  frequency       RecurringFrequency @default(UNKNOWN)
  lastDetectedAt  DateTime           @map("last_detected_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@unique([userId, fingerprint])
  @@map("recurring_patterns")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  before     Json?
  after      Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model PendingConfirmation {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  messageId   String   @map("message_id") @db.Uuid
  contextType String   @map("context_type")
  payload     Json
  expiresAt   DateTime @map("expires_at")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("pending_confirmations")
}

model UserReminder {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @map("user_id") @db.Uuid
  title           String
  notes           String?            @db.Text
  eventAt         DateTime           @map("event_at")
  allDay          Boolean            @default(false) @map("all_day")
  notifyAt        DateTime           @map("notify_at")
  earlyMinutes    Int                @default(15) @map("early_minutes")
  recurrence      ReminderRecurrence @default(NONE)
  recurrenceMeta  Json?              @map("recurrence_meta")
  status          ReminderStatus     @default(ACTIVE)
  timezone        String
  sourceText      String?            @map("source_text") @db.Text
  source          ReminderSource     @default(TEXT)
  sourceMessageId String?            @map("source_message_id") @db.Uuid
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  completedAt     DateTime?          @map("completed_at")
  canceledAt      DateTime?          @map("canceled_at")

  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries ReminderDelivery[]

  @@index([userId, status, notifyAt])
  @@index([status, notifyAt])
  @@map("user_reminders")
}

model ReminderDelivery {
  id         String   @id @default(uuid()) @db.Uuid
  reminderId String   @map("reminder_id") @db.Uuid
  slotAt     DateTime @map("slot_at")
  sentAt     DateTime @default(now()) @map("sent_at")

  reminder UserReminder @relation(fields: [reminderId], references: [id], onDelete: Cascade)

  @@unique([reminderId, slotAt])
  @@index([reminderId])
  @@map("reminder_deliveries")
}
