NODE_ENV=development
PORT=3000
LOG_LEVEL=info

DATABASE_URL=postgresql://finance:finance@localhost:5432/finance_zap?schema=public

# Baileys session files
BAILEYS_AUTH_DIR=./baileys_auth

# Media storage (downloads from WhatsApp)
MEDIA_STORAGE_DIR=./storage/media

# OCR
TESSERACT_LANG=por+eng

# Transcription: optional whisper.cpp binary (see README)
WHISPER_CLI_PATH=
WHISPER_MODEL_PATH=
FFMPEG_PATH=ffmpeg

# Default user timezone when not set
DEFAULT_TIMEZONE=America/Sao_Paulo
DEFAULT_LOCALE=pt-BR
